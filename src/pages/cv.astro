---
import Layout from "@layouts/Layout.astro";
import Container from "@components/Container.astro";
import Link from "@components/Link.astro";

const meta = {
  title: "CV",
  description:
    "Work experience, education and certifications of Eduardo Saldaña — Data Engineer & Power Platform Developer.",
};
---

<Layout title={meta.title} description={meta.description}>
  <Container>
    <aside data-pagefind-ignore>
      <div class="space-y-16">

        <!-- Header -->
        <section>
          <div class="flex flex-col sm:flex-row items-start sm:items-center gap-6 mb-6">
            <img
              src="/avatar.jpg"
              alt="Eduardo Saldana"
              class="rounded-full w-20 h-20 object-cover ring-2 ring-black/10 dark:ring-white/20"
            />
            <div>
              <h1 class="font-semibold text-black dark:text-white mb-1">
                Eduardo Saldaña
              </h1>
              <p class="text-sm text-gray-500 dark:text-gray-400">
                <Link href="https://www.linkedin.com/in/esaldanaf/" external>
                  Data Engineer · Power Platform App Maker
                </Link>
              </p>
            </div>
          </div>
        </section>

        <!-- Work Experience -->
        <section class="animate space-y-8">
          <h2 class="font-semibold text-black dark:text-white">
            Work Experience
          </h2>

          <!-- G.team / Vueling -->
          <div class="space-y-2">
            <div class="flex flex-wrap items-start justify-between gap-y-1">
              <div>
                <p class="font-medium text-black dark:text-white">
                  Data Engineer — Vueling Airlines
                </p>
                <p class="text-sm text-gray-500 dark:text-gray-400">
                  G.team · Hybrid · Zaragoza, Spain
                </p>
              </div>
              <span class="text-sm text-gray-400 dark:text-gray-500 text-nowrap">
                Apr 2023 – May 2026
              </span>
            </div>
            <ul class="space-y-1 text-sm list-disc list-outside ml-4">
              <li>
                Designed and maintained data infrastructure for Vueling, transforming
                complex operational data into strategic assets under Agile (Scrum) methodology.
              </li>
              <li>
                Built ingestion pipelines from heterogeneous sources: PostgreSQL, SQL Server,
                Redshift, REST APIs, SharePoint and web scraping.
              </li>
              <li>
                Designed parametrized ETL/ELT DAGs in Apache Airflow ensuring idempotency
                and smooth environment transitions.
              </li>
              <li>
                Implemented structured logging and observability via the Elasticsearch/Kibana
                stack for pipeline health monitoring.
              </li>
              <li>
                Led CI/CD migration from Jenkins to Azure DevOps, integrating secrets
                management with AWS Secrets Manager.
              </li>
              <li>
                Optimized incremental and full load processes into AWS Redshift and
                PostgreSQL, using Amazon S3 as a data lake.
              </li>
            </ul>
            <div class="flex flex-wrap gap-2 pt-1">
              {[
                "Python", "Pandas", "Apache Airflow", "AWS Redshift",
                "Amazon S3", "Elasticsearch", "Kibana", "Azure DevOps",
                "Jenkins", "SQL Server", "REST APIs", "Scrum",
              ].map((skill) => (
                <span class="rounded-full border border-black/15 px-2 py-0.5 text-xs dark:border-white/20">
                  {skill}
                </span>
              ))}
            </div>
          </div>

          <hr class="border-black/10 dark:border-white/10" />

          <!-- SEGULA / Michelin -->
          <div class="space-y-2">
            <div class="flex flex-wrap items-start justify-between gap-y-1">
              <div>
                <p class="font-medium text-black dark:text-white">
                  Power Platform Engineer — Michelin CEMA
                </p>
                <p class="text-sm text-gray-500 dark:text-gray-400">
                  SEGULA Technologies · Remote · Zaragoza, Spain
                </p>
              </div>
              <span class="text-sm text-gray-400 dark:text-gray-500 text-nowrap">
                Sep 2022 – Mar 2023
              </span>
            </div>
            <ul class="space-y-1 text-sm list-disc list-outside ml-4">
              <li>
                Technical lead on digital transformation and process optimization
                projects at Michelin's CEMA experience center.
              </li>
              <li>
                Replaced physical forms with dynamic applications built in Power Apps
                and Microsoft Forms.
              </li>
              <li>
                Designed operational workflows in Power Automate integrated with
                SharePoint Online databases.
              </li>
              <li>
                Managed the full project lifecycle: from functional analysis to
                deployment and post-implementation support.
              </li>
              <li>
                Obtained the <strong>Microsoft Certified: Power Platform App Maker
                Associate (PL-100)</strong> certification during this period.
              </li>
            </ul>
            <div class="flex flex-wrap gap-2 pt-1">
              {[
                "Power Apps", "Power Automate", "SharePoint Online",
                "Microsoft Forms", "Power Platform",
              ].map((skill) => (
                <span class="rounded-full border border-black/15 px-2 py-0.5 text-xs dark:border-white/20">
                  {skill}
                </span>
              ))}
            </div>
          </div>

          <hr class="border-black/10 dark:border-white/10" />

          <!-- EFOR -->
          <div class="space-y-2">
            <div class="flex flex-wrap items-start justify-between gap-y-1">
              <div>
                <p class="font-medium text-black dark:text-white">
                  Software Developer — Microsoft Power Platform
                </p>
                <p class="text-sm text-gray-500 dark:text-gray-400">
                  EFOR Internet y Tecnología · On-site · Zaragoza, Spain
                </p>
              </div>
              <span class="text-sm text-gray-400 dark:text-gray-500 text-nowrap">
                Oct 2021 – Sep 2022
              </span>
            </div>
            <ul class="space-y-1 text-sm list-disc list-outside ml-4">
              <li>
                Developed, deployed and maintained low-code solutions to digitize
                and optimize business processes.
              </li>
              <li>
                Built custom canvas applications with Power Apps and data architecture
                on Dataverse (including Dataverse for Teams).
              </li>
              <li>
                Designed workflow automations integrating Power Automate with
                SharePoint Online environments.
              </li>
              <li>
                Handled requirements gathering, functional analysis and
                post-deployment technical support.
              </li>
            </ul>
            <div class="flex flex-wrap gap-2 pt-1">
              {[
                "Power Apps", "Power Automate", "Dataverse",
                "SharePoint Online", "Low-Code",
              ].map((skill) => (
                <span class="rounded-full border border-black/15 px-2 py-0.5 text-xs dark:border-white/20">
                  {skill}
                </span>
              ))}
            </div>
          </div>

          <hr class="border-black/10 dark:border-white/10" />

          <!-- Grupo Oesía -->
          <div class="space-y-2">
            <div class="flex flex-wrap items-start justify-between gap-y-1">
              <div>
                <p class="font-medium text-black dark:text-white">
                  Junior Web Developer (Internship)
                </p>
                <p class="text-sm text-gray-500 dark:text-gray-400">
                  Grupo Oesía · Remote · Zaragoza, Spain
                </p>
              </div>
              <span class="text-sm text-gray-400 dark:text-gray-500 text-nowrap">
                Jul 2021 – Sep 2021
              </span>
            </div>
            <ul class="space-y-1 text-sm list-disc list-outside ml-4">
              <li>
                Supported development and maintenance of web applications covering
                both frontend and backend.
              </li>
              <li>
                Resolved incidents and gained hands-on experience with the software
                development lifecycle in a corporate environment.
              </li>
            </ul>
            <div class="flex flex-wrap gap-2 pt-1">
              {["Java", "Angular", "Web Development"].map((skill) => (
                <span class="rounded-full border border-black/15 px-2 py-0.5 text-xs dark:border-white/20">
                  {skill}
                </span>
              ))}
            </div>
          </div>
          
          <hr class="border-black/10 dark:border-white/10" />

          <!-- Previous Experience -->
          <div class="space-y-2">
            <div class="flex flex-wrap items-start justify-between gap-y-1">
              <div>
                <p class="font-medium text-black dark:text-white">
                  Administrative & Documentation Roles
                </p>
                <p class="text-sm text-gray-500 dark:text-gray-400">
                  Various companies · Zaragoza, Spain
                </p>
              </div>
              <span class="text-sm text-gray-400 dark:text-gray-500 text-nowrap">
                2014 – 2019
              </span>
            </div>
            <p class="text-sm">
              Before moving into software development, I worked across HR, legal
              documentation and operations roles — managing payroll, labour contracts,
              data protection compliance and client processes. This background gave me
              a solid understanding of how organisations work from the inside, and
              shaped the way I approach automation and data engineering today: focused
              on solving real business problems, not just technical ones.
            </p>
          </div>
        </section>

        <!-- Education -->
        <section class="animate space-y-6">
          <h2 class="font-semibold text-black dark:text-white">Education</h2>

          <div class="space-y-6">

            <div class="flex flex-wrap items-start justify-between gap-y-1">
              <div>
                <p class="font-medium text-black dark:text-white">
                  AI-Driven Development — Introductory Course
                </p>
                <p class="text-sm text-gray-500 dark:text-gray-400">BIG school</p>
              </div>
              <span class="text-sm text-gray-400 dark:text-gray-500">2025</span>
            </div>

            <div class="flex flex-wrap items-start justify-between gap-y-1">
              <div>
                <p class="font-medium text-black dark:text-white">
                  Vueling Data University
                </p>
                <p class="text-sm text-gray-500 dark:text-gray-400">
                  Centro de Tecnologías Avanzadas · SQL, T-SQL, Python for Data Engineering
                </p>
              </div>
              <span class="text-sm text-gray-400 dark:text-gray-500">2023</span>
            </div>

            <div class="flex flex-wrap items-start justify-between gap-y-1">
              <div>
                <p class="font-medium text-black dark:text-white">
                  Web Development with .NET
                </p>
                <p class="text-sm text-gray-500 dark:text-gray-400">
                  Integra Technology School · C#, ASP.NET MVC, OOP, Software Testing
                </p>
              </div>
              <span class="text-sm text-gray-400 dark:text-gray-500">2021</span>
            </div>

            <div class="flex flex-wrap items-start justify-between gap-y-1">
              <div>
                <p class="font-medium text-black dark:text-white">
                  Higher Technician in Web Application Development (DAW)
                </p>
                <p class="text-sm text-gray-500 dark:text-gray-400">
                  Colegio Montessori · Java, JavaScript, PHP, HTML, CSS, SQL, Bootstrap
                </p>
              </div>
              <span class="text-sm text-gray-400 dark:text-gray-500">2019 – 2021</span>
            </div>

            <div class="flex flex-wrap items-start justify-between gap-y-1">
              <div>
                <p class="font-medium text-black dark:text-white">
                  Master's Degree in Human Resources Management
                </p>
                <p class="text-sm text-gray-500 dark:text-gray-400">
                  EUDE Business School
                </p>
              </div>
              <span class="text-sm text-gray-400 dark:text-gray-500">2013 – 2014</span>
            </div>

            <div class="flex flex-wrap items-start justify-between gap-y-1">
              <div>
                <p class="font-medium text-black dark:text-white">
                  Bachelor's Degree in Labor Sciences
                </p>
                <p class="text-sm text-gray-500 dark:text-gray-400">
                  University of Zaragoza
                </p>
              </div>
              <span class="text-sm text-gray-400 dark:text-gray-500">2010 – 2013</span>
            </div>

            <div class="flex flex-wrap items-start justify-between gap-y-1">
              <div>
                <p class="font-medium text-black dark:text-white">
                  University certificate program in Labor Relations
                </p>
                <p class="text-sm text-gray-500 dark:text-gray-400">
                  University of Zaragoza
                </p>
              </div>
              <span class="text-sm text-gray-400 dark:text-gray-500">2006 – 2010</span>
            </div>

          </div>
        </section>

        <!-- Certifications -->
        <section class="animate space-y-4">
          <h2 class="font-semibold text-black dark:text-white">Certifications</h2>
          <ul class="space-y-3">
            <li class="flex flex-wrap items-start justify-between gap-y-1">
              <div>
                <span class="font-medium">
                  <Link
                    href="https://learn.microsoft.com/api/credentials/share/es-es/EduSaldaa-1886/A65359E036101B0F?sharingId"
                    external
                  >
                    Microsoft Certified: Power Platform App Maker Associate (PL-100)
                  </Link>
                </span>
                <p class="text-sm text-gray-500 dark:text-gray-400">Microsoft</p>
              </div>
              <span class="text-sm text-gray-400 dark:text-gray-500">2023</span>
            </li>
            <li class="flex flex-wrap items-start justify-between gap-y-1">
              <div>
                <span class="font-medium">
                  <Link
                    href="https://mia.aragon.es/documentos?csv=CSVKW5USLK2E81F0DIPL"
                    external
                  >
                    Vueling Data University
                  </Link>
                </span>
                <p class="text-sm text-gray-500 dark:text-gray-400">
                  CTA Aragón · SQL, T-SQL, ETL, Python for Data Engineering
                </p>
              </div>
              <span class="text-sm text-gray-400 dark:text-gray-500">2023</span>
            </li>
          </ul>
        </section>

        <!-- Languages -->
        <section class="animate space-y-4">
          <h2 class="font-semibold text-black dark:text-white">Languages</h2>
          <ul class="space-y-1 text-sm">
            <li class="flex justify-between">
              <span>Spanish</span>
              <span class="text-gray-500 dark:text-gray-400">Native</span>
            </li>
            <li class="flex justify-between">
              <span>English</span>
              <span class="text-gray-500 dark:text-gray-400">
                B1 proficiency
              </span>
            </li>
          </ul>
        </section>

      </div>
    </aside>
  </Container>
</Layout>